    "alert.recording_limit.message" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You have reached the maximum saved recordings. Remove an existing entry to start a new session."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Has alcanzado el máximo de grabaciones guardadas. Elimina una entrada existente para iniciar una nueva sesión."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Has alcanzado el máximo de grabaciones guardadas. Elimina una entrada existente para iniciar una nueva sesión."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您已达到最大保存录制数量。请删除现有条目以开始新会话。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您已達到最大儲存錄製數量。請刪除現有項目以開始新工作階段。"
          }
        }
      }
    },
